generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum PostCategory {
  NEWS
  ARTICLE
  TUTORIAL
  REVIEW
  OPINION
  INTERVIEW
  ANNOUNCEMENT
  OTHER
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  passwordHash         String?
  role                 Role      @default(EDITOR)
  posts                Post[]
  refreshTokenHash     String?
  refreshTokenExpiresAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Post {
  id          String        @id @default(cuid())
  title       String
  excerpt     String?
  slug        String        @unique
  status      ContentStatus @default(DRAFT)
  blocks      Json          @default("[]")
  category    PostCategory  @default(OTHER)
  image       MediaFile?    @relation(fields: [imageId], references: [id])
  imageId     String?
  author      User?         @relation(fields: [authorId], references: [id])
  authorId    String?
  page        Page?         @relation(fields: [pageId], references: [id])
  pageId      String?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([category])
  @@index([pageId])
}

model Page {
  id        String        @id @default(cuid())
  title     String
  slug      String        @unique
  content   Json          @default("[]")
  status    ContentStatus @default(DRAFT)
  posts     Post[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model MediaFile {
  id        String   @id @default(cuid())
  name      String
  url       String
  mimeType  String
  size      Int
  posts     Post[]
  createdAt DateTime @default(now())
}

model NavigationItem {
  id        String           @id @default(cuid())
  label     String
  href      String
  order     Int              @default(0)
  parentId  String?
  parent    NavigationItem?  @relation("NavigationTree", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavigationTree")
  updatedAt DateTime         @updatedAt
}
